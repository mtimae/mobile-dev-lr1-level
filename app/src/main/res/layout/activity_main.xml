<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#F5F7FB">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Цифровой уровень"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1F2937" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Положите телефон на поверхность и наблюдайте за пузырьком"
        android:textSize="14sp"
        android:textColor="#607D8B"
        android:gravity="center" />

    <FrameLayout
        android:id="@+id/levelArea"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/level_frame">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="#B0BEC5" />

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="#B0BEC5" />

        <View
            android:id="@+id/bubble"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/bubble_circle" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Статус: ожидание данных"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#37474F" />

    <TextView
        android:id="@+id/tvXValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="X: 0.00"
        android:textSize="18sp"
        android:textColor="#263238" />

    <TextView
        android:id="@+id/tvYValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Y: 0.00"
        android:textSize="18sp"
        android:textColor="#263238" />

</LinearLayout>